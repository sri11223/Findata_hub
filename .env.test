# Application — test environment overrides
NODE_ENV=test
PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/findata_hub_test
JWT_ACCESS_SECRET=test-access-secret-key-minimum-32-characters
JWT_REFRESH_SECRET=test-refresh-secret-key-minimum-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
BCRYPT_SALT_ROUNDS=4
CORS_ORIGIN=*
LOG_LEVEL=error
